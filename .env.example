# Bot Token from @BotFather
BOT_TOKEN=123456789:ABCDEF...

# Admin Telegram ID
ADMIN_ID=12345678

# Webhook Secret (Optional but recommended)
WEBHOOK_SECRET=my_secure_secret

# Firebase Service Account JSON (required for Vercel/External deployment)
# Get this from Firebase Console -> Settings -> Service Accounts -> Generate Private Key
FIREBASE_SERVICE_ACCOUNT='{"type": "service_account", ...}'

# App URL (Provided by Vercel after deployment)
APP_URL=https://your-bot-name.vercel.app
